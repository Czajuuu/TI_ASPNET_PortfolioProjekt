@model IEnumerable<Portfolio.Backend.Models.Project>

@{
    ViewData["Title"] = "Panel Zarządzania (CMS) - Projekty";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="m-0">Zarządzanie Projektami Wideo</h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Dodaj Nowy Projekt
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0 table-responsive">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th scope="col" class="ps-4">Tytuł</th>
                    <th scope="col">Kategoria</th>
                    <th scope="col">Typ Wideo</th>
                    <th scope="col" class="text-end pe-4">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">Brak projektów w bazie.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 align-middle fw-bold">@item.Title</td>
                            <td class="align-middle">
                                <span class="badge bg-secondary">@item.Subtitle</span>
                            </td>
                            <td class="align-middle text-uppercase small text-muted">
                                @item.VideoType
                            </td>
                            <td class="text-end pe-4 align-middle">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edytuj</a>
                                
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Czy na pewno chcesz usunąć ten projekt? Ta operacja jest nieodwracalna.');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Usuń</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
