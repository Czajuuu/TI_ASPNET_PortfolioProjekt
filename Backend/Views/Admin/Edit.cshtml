@model Portfolio.Backend.Models.Project

@{
    ViewData["Title"] = "Edytuj Projekt";
}

<div class="mb-4">
    <h2>Edycja Projektu Wideo: @Model.Title</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-2">&larr; Powrót do listy</a>
</div>

<div class="card shadow-sm border-primary">
    <div class="card-body">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Title" class="form-label fw-bold">Tytuł projektu <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Subtitle" class="form-label fw-bold">Podtytuł / Kategoria <span class="text-danger">*</span></label>
                    <input asp-for="Subtitle" class="form-control" />
                    <span asp-validation-for="Subtitle" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-bold">Opis projektu <span class="text-danger">*</span></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Tags" class="form-label fw-bold">Tagi technologiczne <span class="text-danger">*</span></label>
                <input asp-for="Tags" class="form-control" />
                <span asp-validation-for="Tags" class="text-danger"></span>
                <div class="form-text">Użyj przecinka, aby rozdzielić poszczególne tagi. Frontend sam zamieni je na kafelki.</div>
            </div>

            <hr class="my-4" />
            <h5 class="mb-3">Źródła Wideo & Zdjęcia</h5>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Type" class="form-label fw-bold">Typ Posta</label>
                    <select asp-for="Type" class="form-select">
                        <option value="video">Wideo (video)</option>
                        <option value="web">Strona www (web)</option>
                    </select>
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="VideoType" class="form-label fw-bold">Sposób osadzenia wideo</label>
                    <select asp-for="VideoType" class="form-select">
                        <option value="local">Plik lokalny z serwera (local)</option>
                        <option value="youtube">Link z YouTube (youtube)</option>
                        <option value="placeholder">Brak wideo (placeholder)</option>
                    </select>
                    <span asp-validation-for="VideoType" class="text-danger"></span>
                </div>
            </div>

            <!-- Zachowujemy dotychczasowe ścieżki w ukrytych polach, na wypadek gdyby użytkownik nie wgrywał nowych plików -->
            <input type="hidden" asp-for="VideoSrc" />
            <input type="hidden" asp-for="VideoSrcEn" />
            <input type="hidden" asp-for="VideoSrcDe" />
            <input type="hidden" asp-for="Thumb" />

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Podmień Wideo (PL)</label>
                    <input type="file" name="uploadedVideoSrc" class="form-control" accept="video/mp4,video/webm" />
                    <div class="form-text text-truncate">Obecne: @Model.VideoSrc</div>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Podmień Wideo (EN)</label>
                    <input type="file" name="uploadedVideoSrcEn" class="form-control" accept="video/mp4,video/webm" />
                    <div class="form-text text-truncate">Obecne: @Model.VideoSrcEn</div>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Podmień Wideo (DE)</label>
                    <input type="file" name="uploadedVideoSrcDe" class="form-control" accept="video/mp4,video/webm" />
                    <div class="form-text text-truncate">Obecne: @Model.VideoSrcDe</div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Podmień miniaturę (Thumb)</label>
                    <input type="file" name="uploadedThumb" class="form-control" accept="image/*" />
                    <div class="form-text text-truncate">Obecne: @Model.Thumb</div>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Link" class="form-label">Zewnętrzny Link (dla stron www)</label>
                    <input asp-for="Link" class="form-control" />
                    <span asp-validation-for="Link" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary px-5 fw-bold">Zaktualizuj Projekt</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
