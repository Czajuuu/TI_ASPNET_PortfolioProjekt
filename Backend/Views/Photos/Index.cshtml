@model IEnumerable<Portfolio.Backend.Models.Photo>

@{
    ViewData["Title"] = "Panel Zarządzania (CMS) - Galeria Zdjęć";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="m-0">Galeria Zdjęć</h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Dodaj Nowe Zdjęcie
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0 table-responsive">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th scope="col" class="ps-4">Miniatura</th>
                    <th scope="col">Opis (Caption)</th>
                    <th scope="col">Tekst alternatywny (Alt)</th>
                    <th scope="col" class="text-end pe-4">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">Brak zdjęć w galerii.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 align-middle">
                                @if(!string.IsNullOrEmpty(item.Src)) {
                                    <img src="http://localhost:5173@(item.Src)" alt="thumb" style="max-height: 50px; border-radius: 4px;" />
                                }
                            </td>
                            <td class="align-middle fw-bold">@item.Caption</td>
                            <td class="align-middle text-muted">@item.Alt</td>
                            <td class="text-end pe-4 align-middle">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edytuj</a>
                                
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Czy na pewno chcesz usunąć to zdjęcie?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Usuń</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
